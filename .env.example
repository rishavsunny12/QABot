# Database
DATABASE_URL=postgresql+asyncpg://autoqa:autoqa@postgres:5432/autoqa
POSTGRES_USER=autoqa
POSTGRES_PASSWORD=autoqa
POSTGRES_DB=autoqa

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security / Auth
# Generate secrets before any shared deployment — do not use these defaults.
CREDENTIALS_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
AUTH_MODE=dev
JWT_SECRET=change-me-in-production-use-long-random-string
FRONTEND_URL=http://localhost:3000
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Billing (disabled in OSS v1 — enable in v2)
BILLING_ENABLED=false
BILLING_ENFORCEMENT=false
STRIPE_WEBHOOK_SECRET=

# AI (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# App
ARTIFACTS_DIR=/app/artifacts
CRAWL_MAX_PAGES=50
CRAWL_MAX_DEPTH=3
DEFAULT_PARALLEL_WORKERS=4
MAX_PARALLEL_WORKERS=8
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Set to true when billing is enabled (v2)
NEXT_PUBLIC_BILLING_ENABLED=false
